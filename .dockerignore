# PocketGraphRAG .dockerignore
# 减小构建上下文体积，加速构建

# 版本控制
.git
.gitignore

# IDE
.vscode
.idea
*.swp

# Python 缓存
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# 虚拟环境
venv/
env/
.venv/

# 测试和文档
PocketGraphRAG/tests/
docs/
*.md
!README.md
!CHANGELOG.md

# 构建产物
dist/
build/
*.egg

# 数据和模型（用户运行时挂载）
index/
user_docs/
data/
models/

# 前端源码（仅保留 dist）
frontend/node_modules/
frontend/src/
frontend/package.json
frontend/package-lock.json
frontend/tsconfig*.json
frontend/vite.config.ts
frontend/tailwind.config.js
frontend/postcss.config.js

# 临时文件
*.log
*.tmp
.tmp_*
.git_commit_msg.txt

# 简历/面试等无关文件
resume*
interview*
*_crash_course*
gen_*.py
