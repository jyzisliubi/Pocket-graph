# =============================================================================
# PocketGraphRAG 配置文件模板
# 复制此文件为 .env 并填入你的 API Key 即可使用
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env
# =============================================================================

# --- LLM API 配置（任选其一即可，均使用 POCKET_ 前缀）---

# 选项 1: SiliconFlow 硅基流动（推荐，国内访问快，有免费额度）
# 申请地址: https://siliconflow.cn/
# POCKET_SILICONFLOW_API_KEY=sk-your-key-here
# POCKET_SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# 选项 2: DeepSeek（推理能力强，有免费额度）
# 申请地址: https://platform.deepseek.com/
# POCKET_DEEPSEEK_API_KEY=sk-your-key-here
# POCKET_DEEPSEEK_MODEL=deepseek-chat

# 选项 3: 阿里云 DashScope 通义千问（VLM 图片识别推荐）
# 申请地址: https://dashscope.console.aliyun.com/
# POCKET_DASHSCOPE_API_KEY=sk-your-key-here
# POCKET_DASHSCOPE_MODEL=qwen-plus
# POCKET_DASHSCOPE_VLM_MODEL=qwen-vl-plus

# 选项 4: OpenAI 或其他兼容接口
# POCKET_OPENAI_API_KEY=sk-your-key-here
# POCKET_OPENAI_API_BASE=https://api.openai.com/v1
# POCKET_OPENAI_MODEL=gpt-3.5-turbo

# 选项 5: Ollama 本地模型（完全离线）
# 安装 Ollama: https://ollama.com/
# 拉取模型: ollama pull qwen2.5:7b
# POCKET_OLLAMA_MODEL=qwen2.5:7b
# POCKET_OLLAMA_API_BASE=http://localhost:11434/v1

# --- 可选配置 ---

# 数据路径（默认使用 examples/rice_disease 示例数据）
# POCKET_DATA_PATH=./examples/rice_disease/data/rice_knowledge_graph_triples.txt

# Embedding 模型（默认使用 BAAI/bge-small-zh-v1.5 中文小模型）
# POCKET_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 检索模式: vector / local / global / mix / kg_only
# POCKET_SEARCH_MODE=mix

# 融合策略: rrf (Reciprocal Rank Fusion) 或 weighted
# POCKET_FUSION_STRATEGY=rrf

# RRF 融合的 k 参数（默认 60，业界常用值；越小越看重高排名结果）
# POCKET_RRF_K=60

# 混合检索时向量结果权重 (0.0~1.0)，KG 结果权重 = 1 - VECTOR_WEIGHT
# 默认 0.3 偏向 KG：评测显示纯 KG MRR=0.55 远高于纯向量 0.21，
# VW=0.3 时 mix MRR=0.48（接近 kg_only），VW=0.4 时 MRR=0.40
# 想更偏向 KG 可设 0.1~0.2；想更偏向向量可设 0.5~0.6
# POCKET_VECTOR_WEIGHT=0.3

# Reranker 模型（用于检索精排，默认关闭）
# 注意：rice_disease_v1 评测显示 CrossEncoder 会打乱 KG 优质排序（MRR 0.48→0.35），
# 且推理慢 5x。KG 实体级排序已足够精确，建议仅纯向量模式手动开启。
# 调用方式：rag.retrieve(query, use_reranker=True)
# 默认 bge-reranker-v2-m3（多语言、效果优于 base）
# 国内首次使用需预先下载缓存，或设 HF_ENDPOINT=https://hf-mirror.com 走镜像
# 完全离线环境设 HF_HUB_OFFLINE=1 强制只用本地缓存
# POCKET_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
# HF_ENDPOINT=https://hf-mirror.com

# --- API 安全配置（部署到公网时建议启用）---
# POCKET_API_KEY=your-secret-api-key
# POCKET_CORS_ORIGINS=https://your-frontend.com
# POCKET_CORS_CREDENTIALS=true
