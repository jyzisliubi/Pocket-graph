# EditorConfig — 跨编辑器统一编码风格
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json,yml,yaml,css,html,md}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2
